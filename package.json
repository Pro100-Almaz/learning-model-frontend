{
  "name": "ent-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Qadam ЕНТ prep platform — Vue 3 SPA frontend (see ../learning-model/plan)",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.vue --max-warnings=0",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "vue-tsc --noEmit",
    "openapi:gen": "openapi-typescript ../learning-model/plan/openapi.yaml -o src/shared/lib/api/schema.ts",
    "mock:api": "prism mock ../learning-model/plan/openapi.yaml"
  },
  "dependencies": {
    "@clerk/vue": "^2.4.7",
    "@tanstack/vue-query": "^5.59.0",
    "@vee-validate/zod": "^4.13.2",
    "@vueuse/core": "^11.1.0",
    "@vueuse/motion": "^2.2.5",
    "axios": "^1.7.7",
    "echarts": "^5.5.1",
    "pinia": "^2.2.4",
    "reka-ui": "^2.0.0",
    "vee-validate": "^4.13.2",
    "vue": "^3.5.11",
    "vue-echarts": "^7.0.3",
    "vue-router": "^4.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@fontsource/onest": "^5.1.0",
    "@fontsource/unbounded": "^5.1.0",
    "@stoplight/prism-cli": "^5.12.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.7.4",
    "@vitejs/plugin-vue": "^5.1.4",
    "@vue/eslint-config-typescript": "^14.0.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.5.1",
    "eslint": "^9.12.0",
    "eslint-plugin-vue": "^9.28.0",
    "jsdom": "^25.0.1",
    "openapi-typescript": "^7.4.1",
    "prettier": "^3.3.3",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.6.2",
    "vite": "^5.4.8",
    "vite-plugin-pwa": "^0.20.5",
    "vitest": "^2.1.2",
    "vue-tsc": "^2.1.6"
  }
}
