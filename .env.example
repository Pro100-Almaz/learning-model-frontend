# Backend API root (e.g. https://api.staging.example.com/api/v1 in staging, http://localhost:8000/api/v1 locally).
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Clerk publishable key from the Clerk dashboard.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_replace_me

# Optional but recommended for this backend:
# create a Clerk JWT template whose claims include email and first_name, then put the template name here.
VITE_CLERK_JWT_TEMPLATE=qadam_jwt_template
